# Yojana-Setu Environment Configuration
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://yojana:yojana_dev_password@localhost:5432/yojana_setu
REDIS_URL=redis://:yojana_redis_dev@localhost:6379

# ─── S3 / Object Storage ─────────────────────────────────────────────────────
# For local dev, MinIO is used as an S3-compatible store
S3_BUCKET_NAME=yojana-setu-documents
S3_REGION=ap-south-1
# For local MinIO:
AWS_ACCESS_KEY_ID=yojana_minio
AWS_SECRET_ACCESS_KEY=yojana_minio_dev_password
# For local MinIO, override the S3 endpoint:
# S3_ENDPOINT=http://localhost:9000

# ─── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change all of these in production. Use 32+ char random strings.
JWT_SECRET=CHANGE_ME_USE_32_CHAR_RANDOM_STRING_HERE
ENCRYPTION_KEY=CHANGE_ME_USE_EXACTLY_32_CHARS!!!
API_KEY_SALT=CHANGE_ME_16_CHARS

# ─── Bhashini API ─────────────────────────────────────────────────────────────
# Register at: https://bhashini.gov.in/ulca/search
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_BASE_URL=https://dhruva-api.bhashini.gov.in

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# Provider: 'twilio' (recommended for dev) or 'meta'
WHATSAPP_PROVIDER=twilio

# Twilio (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # Twilio sandbox number

# Meta / Direct (get from https://developers.facebook.com)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_VERIFY_TOKEN=CHANGE_ME_VERIFY_TOKEN

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# ─── OCR ──────────────────────────────────────────────────────────────────────
# 'textract' uses AWS credentials above. 'google_vision' needs GOOGLE_APPLICATION_CREDENTIALS.
OCR_PROVIDER=textract

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Sessions ─────────────────────────────────────────────────────────────────
SESSION_INACTIVITY_TIMEOUT_HOURS=24
