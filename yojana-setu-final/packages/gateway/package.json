{
  "name": "@yojana-setu/gateway",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:property": "jest --testPathPattern=property"
  },
  "dependencies": {
    "@yojana-setu/shared": "workspace:*",
    "express": "^4.18.3",
    "dotenv": "^16.4.5",
    "zod": "^3.22.4",
    "winston": "^3.12.0",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.25",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2",
    "fast-check": "^3.17.1"
  }
}
