    "@types/node": "^20.11.25",
    "@types/pg": "^8.11.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2",
    "fast-check": "^3.17.1"
